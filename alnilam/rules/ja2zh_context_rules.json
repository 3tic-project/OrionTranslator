{
  "version": "0.2",
  "description": "Japanese→Chinese document-level translation: dynamic previous-context window detector (rule-based) — enhanced v2",
  "boundaries": {
    "scene_break_regex": [
      "^[\\s　]*[◆◇■□★☆※＊*＝=─—―-]{3,}[\\s　]*$",
      "^[\\s　]*[○●◎]{3,}[\\s　]*$"
    ],
    "chapter_heading_regex": [
      "^(?:目次|Contents)$",
      "^(?:プロローグ|エピローグ|Prologue|Epilogue)(?:\\s|　|$)",
      "^(?:序章|終章|最終章|断章|幕間|間章|閑話|番外編|おまけ)(?:\\s|　|$)",
      "^(?:第[0-9０-９一二三四五六七八九十百千]+[章話節部篇幕回])(?:\\s|　|$)",
      "^(?:[一二三四五六七八九十]+章)(?:\\s|　|$)",
      "^研修[0-9０-９]+(?:\\s|　|$)",
      "^(?:Chapter|CHAPTER)\\s*[0-9IVXivx]+(?:\\s|　|$)"
    ],
    "metadata_regex": [
      "^ダッシュエックス文庫DIGITAL$",
      "^本書に掲載されているコンテンツ$",
      "^本書の内容を権利者$",
      "^(?:©|ⒸISBN|ISBN|奥付|著者|イラスト|発行)",
      "^(?:電子書籍|電子版|初版発行|再版|第[0-9]+刷)"
    ]
  },
